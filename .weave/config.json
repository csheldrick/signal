{
  "project": "signal",
  "dbPath": ".weave/substrate.db",
  "decayRate": 0.05,
  "propagationDamping": 0.7,
  "propagationThreshold": 0.01,
  "activationCeiling": 1.0,
  "propagationMaxDepth": 8,
  "tickIntervalMs": 1000,
  "operatorActivationThreshold": 0.3,
  "confidencePropagationEveryNTicks": 5,
  "evolutionRecordEveryNTicks": 10,
  "maintenanceEveryNTicks": 50,
  "evolve": {
    "dir": "app",
    "variants": 4,
    "isolation": "worktree",
    "fitness": {
      "probe": "test",
      "command": "npm test",
      "perCapabilityCommand": "npx vitest run tests/{capability}.test.ts",
      "score": "passRate",
      "tieBreaker": "activationCost"
    },
    "curiosity": {
      "enabled": true,
      "weight": 0.2,
      "signal": "exploration_needed",
      "rewards": "underActivatedRegions"
    }
  },
  "docs": {
    "sources": [
      { "root": "workspace", "glob": "goals/**/*.md", "nodeType": "goal", "edgeType": "supports" },
      { "root": "workspace", "glob": "observations/**/*.md", "nodeType": "observation", "edgeType": "related_to" },
      { "root": "workspace", "glob": "architecture/decisions/**/*.md", "nodeType": "concept", "edgeType": "related_to" },
      { "root": "workspace", "glob": "architecture/constraints/**/*.md", "nodeType": "abstraction", "edgeType": "blocks" },
      { "root": "workspace", "glob": "architecture/experiments/**/*.md", "nodeType": "hypothesis", "edgeType": "predicts" },
      { "root": "workspace", "glob": "tasks/**/*.md", "nodeType": "task", "edgeType": "related_to" }
    ],
    "output": {
      "root": "workspace",
      "templates": [
        {
          "id": "experiment",
          "file": "architecture/experiments/weave-results.md",
          "body": "### Cohort {{variantGroupId}}\n\n- **Origin**: {{origin}}\n- **Survivors**: {{survivors}}\n- **Pruned**: {{pruned}}\n- **Fitness**: {{fitness}}\n- **Timestamp**: {{timestamp}}"
        }
      ]
    }
  }
}
